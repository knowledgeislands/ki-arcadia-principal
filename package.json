{
  "name": "@knowledgeislands/ki-arcadia-principal",
  "description": "The core knowledge repository of the Knowledge Islands project — governance base, evolving KB, and decision record.",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bugs": {
    "url": "https://github.com/knowledgeislands/ki-arcadia-principal/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "knip": "^6.25.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.9.4",
    "syncpack": "^15.3.2",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://github.com/knowledgeislands/ki-arcadia-principal#readme",
  "keywords": [
    "arcadia",
    "knowledge-base",
    "knowledge-islands",
    "markdown"
  ],
  "license": "UNLICENSED",
  "lint-staged": {
    "*.{ts,js,mjs,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2"
    ]
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/ki-arcadia-principal.git"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "ki:audit": "bun scripts/ki/aggregate.ts audit",
    "ki:authoring:audit": "bun .claude/skills/ki-authoring/scripts/audit-authoring.ts .",
    "ki:conform": "bun run ki:deps:refresh && bun run ki:lint:package && bun run ki:lint:format && bun run ki:lint:fix && bun run ki:lint:md",
    "ki:decision-records:audit": "bun .claude/skills/ki-decision-records/scripts/audit-drs.ts .",
    "ki:deps:check": "bunx knip --dependencies --no-config-hints",
    "ki:deps:fix": "bunx knip --dependencies --fix --no-config-hints",
    "ki:deps:refresh": "bun update --force",
    "ki:deps:update": "bun update --latest && bun install",
    "ki:engineering:audit": "bun .claude/skills/ki-engineering/scripts/audit-engineering.ts .",
    "ki:init": "bun scripts/ki/aggregate.ts init",
    "ki:kb-base:audit": "bun .claude/skills/ki-kb-base/scripts/audit-kb.ts .",
    "ki:kb-streams:audit": "bun .claude/skills/ki-kb-streams/scripts/audit-streams.ts .",
    "ki:knip": "bunx knip --no-config-hints",
    "ki:lint:check": "bunx @biomejs/biome check",
    "ki:lint:fix": "bunx @biomejs/biome check --write --unsafe",
    "ki:lint:format": "bunx @biomejs/biome format --write",
    "ki:lint:md": "bunx prettier --write \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "ki:lint:md:check": "bunx prettier --check \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "ki:lint:package": "bunx syncpack format",
    "ki:lint:types": "tsc --noEmit",
    "ki:repo:audit": "bun .claude/skills/ki-repo/scripts/audit-repo.ts .",
    "ki:repo:conform": "bun scripts/ki/ki-repo/conform-repo.ts .",
    "ki:skills:link:project": "bun $HOME/.claude/skills/knowledgeislands-bootstrap/scripts/link-skills.ts",
    "ki:tokenomics:audit": "bun .claude/skills/ki-tokenomics/scripts/audit-tokenomics.ts .",
    "ki:verify": "bun run ki:lint:check && bun run ki:lint:types && bun run ki:lint:md:check && bun run ki:knip",
    "prepare": "husky"
  },
  "type": "module"
}
