{
  "name": "@knowledgeislands/arcadia-principal",
  "description": "The core knowledge repository of the Knowledge Islands project, serving as the primary hub of evolving ideas and governance",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bugs": {
    "url": "https://github.com/knowledgeislands/arcadia-principal/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^26.0.0",
    "husky": "^9.1.7",
    "json5": "^2.2.3",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "syncpack": "^15.3.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://github.com/knowledgeislands/arcadia-principal#readme",
  "keywords": [
    "arcadia",
    "knowledge-base",
    "knowledge-islands",
    "markdown"
  ],
  "license": "UNLICENSED",
  "lint-staged": {
    "*.{ts,js,mjs,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2"
    ]
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/arcadia-principal.git"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "deps:missing": "bunx depcheck --json | bunx node-jq --sort-keys '.' | bunx node-jq '.missing | keys | .[]' | xargs bun add -D",
    "deps:unused": "bunx depcheck --json | bunx node-jq --sort-keys '.' | bunx node-jq '.devDependencies[]' | xargs bun remove",
    "deps:update": "bun update --latest",
    "lint:check": "bunx @biomejs/biome check",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe",
    "lint:format": "bunx @biomejs/biome format --write",
    "lint:md": "bunx prettier --write \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "lint:md:check": "bunx prettier --check \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "lint:package": "bunx syncpack format",
    "lint:types": "tsc --noEmit",
    "prepare": "husky",
    "skills:link:project": "bun $HOME/.claude/skills/knowledgeislands-bootstrap/scripts/link-skills.ts"
  },
  "type": "module"
}
