{
  "name": "@knowledgeislands/ki-arcadia-principal",
  "description": "The core knowledge repository of the Knowledge Islands project — governance base, evolving KB, and decision record.",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bugs": {
    "url": "https://github.com/knowledgeislands/ki-arcadia-principal/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.5",
    "syncpack": "^15.3.2",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://github.com/knowledgeislands/ki-arcadia-principal#readme",
  "keywords": [
    "arcadia",
    "knowledge-base",
    "knowledge-islands",
    "markdown"
  ],
  "license": "UNLICENSED",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "bunx @biomejs/biome check --write --no-errors-on-unmatched"
    ],
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2 --no-globs"
    ]
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/ki-arcadia-principal.git"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "ki:audit": "bun .ki-meta/bin/aggregate.ts audit",
    "ki:authoring:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-authoring",
    "ki:authoring:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-authoring",
    "ki:conform": "bun .ki-meta/bin/aggregate.ts conform",
    "ki:decision-records:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-decision-records",
    "ki:decision-records:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-decision-records",
    "ki:educate": "bun .ki-meta/bin/aggregate.ts educate",
    "ki:engineering:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-engineering",
    "ki:engineering:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-engineering",
    "ki:help": "bun .ki-meta/bin/aggregate.ts help",
    "ki:init": "bun scripts/ki/aggregate.ts init",
    "ki:kb-activities:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-kb-activities",
    "ki:kb-activities:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-kb-activities",
    "ki:kb-base:audit": "bun .claude/skills/ki-kb-base/scripts/audit-kb.ts .",
    "ki:kb-live-artifacts:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-kb-live-artifacts",
    "ki:kb-live-artifacts:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-kb-live-artifacts",
    "ki:kb-streams:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-kb-streams",
    "ki:kb-streams:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-kb-streams",
    "ki:kb:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-kb",
    "ki:kb:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-kb",
    "ki:repo:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-repo",
    "ki:repo:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-repo",
    "ki:skills:link:project": "bun $HOME/.claude/skills/knowledgeislands-bootstrap/scripts/link-skills.ts",
    "ki:tokenomics:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-tokenomics",
    "ki:tokenomics:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-tokenomics",
    "prepare": "husky"
  },
  "type": "module"
}
